# ============================================================
# Docker / Compose
# ============================================================
APP_PORT=80
UID=1000
GID=1000

FORWARD_DB_PORT=3306
FORWARD_REDIS_PORT=6379

# ============================================================
# Laravel
# ============================================================
APP_NAME="CRM Meta"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_URL=http://crm-meta.localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ============================================================
# Database (mismos valores los usa docker-compose para MySQL)
# ============================================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=crm_meta
DB_USERNAME=crm
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret

# ============================================================
# Redis (cache, queue, sessions)
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ============================================================
# Mail
# ============================================================
MAIL_MAILER=log

# ============================================================
# Meta Lead Ads Webhook
# ============================================================
META_VERIFY_TOKEN=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# ============================================================
# Google OAuth (sign in to the admin panel with Google)
# Redirect URI in Google Cloud Console must match:
#   {APP_URL}/admin/oauth/callback/google
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=   # optional override; defaults to APP_URL + /admin/oauth/callback/google
